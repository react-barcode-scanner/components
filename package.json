{
    "name": "@react-barcode-scanner/components",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/react-barcode-scanner/components.git",
        "directory": "packages/@react-barcode-scanner/components"
    },
    "version": "0.0.73",
    "license": "MIT",
    "private": false,
    "main": "index.js",
    "module": "esm/index.js",
    "files": [
        "dist",
        "dist/esm"
    ],
    "types": "dist/index.d.ts",
    "dependencies": {
        "@react-barcode-scanner/hooks": "0.0.73"
    },
    "scripts": {
        "rollup": "rollup -c --interop 'auto'",
        "storybook": "storybook dev -p 6006 --https --ssl-cert ./scripts/localhost.crt --ssl-key ./scripts/localhost.key",
        "build-storybook": "storybook build",
        "deploy-storybook": "yarn build-storybook; node scripts/gh-pages-deploy.js"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "registry": "https://registry.npmjs.org"
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">1%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "28.0.7",
        "@rollup/plugin-node-resolve": "16.0.2",
        "@rollup/plugin-typescript": "12.3.0",
        "@storybook/addon-links": "10.3.3",
        "@storybook/react": "10.3.3",
        "@storybook/react-vite": "10.3.3",
        "@types/node": "24.12.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "@vitejs/plugin-react": "4.3.4",
        "autoprefixer": "10.4.21",
        "gh-pages": "6.3.0",
        "postcss": "8.4.49",
        "prettier": "3.4.2",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "rollup": "4.60.0",
        "rollup-plugin-dts": "6.4.1",
        "rollup-plugin-exclude-dependencies-from-bundle": "1.1.24",
        "rollup-plugin-postcss": "4.0.2",
        "storybook": "10.3.3",
        "typescript": "5.7.2",
        "vite": "7.3.1"
    },
    "peerDependencies": {
        "react": "18 - 19",
        "react-dom": "18 - 19"
    }
}
